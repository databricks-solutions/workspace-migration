{
  "datasets": [
    {
      "name": "latest_status",
      "displayName": "Latest Migration Status",
      "queryLines": [
        "SELECT * FROM (\n",
        "  SELECT *,\n",
        "    ROW_NUMBER() OVER (PARTITION BY object_name, object_type ORDER BY migrated_at DESC) AS rn\n",
        "  FROM migration_tracking.cp_migration.migration_status\n",
        ") WHERE rn = 1"
      ]
    },
    {
      "name": "status_summary",
      "displayName": "Status Summary",
      "queryLines": [
        "SELECT status, COUNT(*) AS n\n",
        "FROM (\n",
        "  SELECT status,\n",
        "    ROW_NUMBER() OVER (PARTITION BY object_name, object_type ORDER BY migrated_at DESC) AS rn\n",
        "  FROM migration_tracking.cp_migration.migration_status\n",
        ") WHERE rn = 1\n",
        "GROUP BY status\n",
        "ORDER BY n DESC"
      ]
    },
    {
      "name": "object_type_breakdown",
      "displayName": "By Object Type",
      "queryLines": [
        "SELECT object_type, status, COUNT(*) AS n\n",
        "FROM (\n",
        "  SELECT object_type, status,\n",
        "    ROW_NUMBER() OVER (PARTITION BY object_name, object_type ORDER BY migrated_at DESC) AS rn\n",
        "  FROM migration_tracking.cp_migration.migration_status\n",
        ") WHERE rn = 1\n",
        "GROUP BY object_type, status\n",
        "ORDER BY object_type, n DESC"
      ]
    },
    {
      "name": "recent_activity",
      "displayName": "Recent Migrations",
      "queryLines": [
        "SELECT migrated_at, object_type, object_name, status, error_message, duration_seconds\n",
        "FROM migration_tracking.cp_migration.migration_status\n",
        "ORDER BY migrated_at DESC\n",
        "LIMIT 200"
      ]
    },
    {
      "name": "failures",
      "displayName": "Failures",
      "queryLines": [
        "SELECT object_name, object_type, status, error_message, migrated_at\n",
        "FROM (\n",
        "  SELECT *,\n",
        "    ROW_NUMBER() OVER (PARTITION BY object_name, object_type ORDER BY migrated_at DESC) AS rn\n",
        "  FROM migration_tracking.cp_migration.migration_status\n",
        ") WHERE rn = 1 AND status IN ('failed', 'validation_failed')"
      ]
    },
    {
      "name": "row_count_validation",
      "displayName": "Row Count Validation",
      "queryLines": [
        "SELECT object_name, object_type, source_row_count, target_row_count,\n",
        "  CASE WHEN source_row_count = target_row_count THEN 'match' ELSE 'mismatch' END AS row_count_check,\n",
        "  migrated_at\n",
        "FROM (\n",
        "  SELECT *,\n",
        "    ROW_NUMBER() OVER (PARTITION BY object_name, object_type ORDER BY migrated_at DESC) AS rn\n",
        "  FROM migration_tracking.cp_migration.migration_status\n",
        ") WHERE rn = 1 AND source_row_count IS NOT NULL AND target_row_count IS NOT NULL\n",
        "ORDER BY row_count_check DESC, object_name"
      ]
    },
    {
      "name": "pre_check_latest",
      "displayName": "Latest Pre-Check Results",
      "queryLines": [
        "SELECT check_name, status, message, action_required, checked_at FROM (\n",
        "  SELECT *,\n",
        "    ROW_NUMBER() OVER (PARTITION BY check_name ORDER BY checked_at DESC) AS rn\n",
        "  FROM migration_tracking.cp_migration.pre_check_results\n",
        ") WHERE rn = 1\n",
        "ORDER BY CASE status WHEN 'FAIL' THEN 0 WHEN 'WARN' THEN 1 ELSE 2 END, check_name"
      ]
    },
    {
      "name": "discovery_counts",
      "displayName": "Discovery Inventory",
      "queryLines": [
        "SELECT object_type, COUNT(*) AS count\n",
        "FROM migration_tracking.cp_migration.discovery_inventory\n",
        "GROUP BY object_type\n",
        "ORDER BY count DESC"
      ]
    },
    {
      "name": "policy_protected_tables",
      "displayName": "Policy-Protected Tables (Excluded)",
      "queryLines": [
        "SELECT object_name, error_message AS reason, migrated_at\n",
        "FROM (\n",
        "  SELECT *,\n",
        "    ROW_NUMBER() OVER (PARTITION BY object_name, object_type ORDER BY migrated_at DESC) AS rn\n",
        "  FROM migration_tracking.cp_migration.migration_status\n",
        ") WHERE rn = 1 AND status = 'skipped_policy_protected'\n"
      ]
    },
    {
      "name": "mount_prerequisites",
      "displayName": "Mount Prerequisites (/mnt)",
      "queryLines": [
        "SELECT object_name, storage_location, metadata_json\n",
        "FROM migration_tracking.cp_migration.discovery_inventory\n",
        "WHERE object_type = 'mount_prerequisite'"
      ]
    },
    {
      "name": "dbfs_root_copies",
      "displayName": "DBFS-root Tables Copied",
      "queryLines": [
        "SELECT object_name, status, source_row_count, target_row_count, migrated_at\n",
        "FROM (\n",
        "  SELECT *, ROW_NUMBER() OVER (PARTITION BY object_name, object_type ORDER BY migrated_at DESC) AS rn\n",
        "  FROM migration_tracking.cp_migration.migration_status\n",
        "  WHERE object_type = 'hive_managed_dbfs_root'\n",
        ") WHERE rn = 1"
      ]
    },
    {
      "name": "hive_skipped_failed",
      "displayName": "Hive Skipped / Failed",
      "queryLines": [
        "SELECT object_name, object_type, status, error_message, migrated_at\n",
        "FROM (\n",
        "  SELECT *, ROW_NUMBER() OVER (PARTITION BY object_name, object_type ORDER BY migrated_at DESC) AS rn\n",
        "  FROM migration_tracking.cp_migration.migration_status\n",
        "  WHERE object_type LIKE 'hive_%'\n",
        ") WHERE rn = 1 AND status IN ('failed', 'validation_failed', 'skipped', 'skipped_by_config')"
      ]
    }
  ],
